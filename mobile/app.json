{
  "expo": {
    "name": "Ustaad",
    "slug": "ustaad",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/logomark_foreground.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/logomark_foreground.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.aliahsann15.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/logomark_foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aliahsann15.mobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withAsyncStorageLocalRepo",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logomark.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f8e47b17-4e6a-4d7c-8f43-1b0d9b414c96"
      }
    },
    "owner": "aliahsann15"
  }
}
